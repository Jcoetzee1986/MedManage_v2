# MedManage.Modern — Environment Variables for Podman Compose
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# SQL Server password (your host database SA or application login password)
DB_PASSWORD=YourPassword123

# JWT signing key (minimum 32 characters, use a random string)
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
