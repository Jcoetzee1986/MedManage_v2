	},
	"item": [
		{
			"name": "Member CRUD Operations",
			"item": [
				{
					"name": "1. Create Member - Valid",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has success=true\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"",
									"pm.test(\"Response contains member data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.be.an('object');",
									"    pm.expect(jsonData.data.memberId).to.be.a('number');",
									"    pm.expect(jsonData.data.memberNumber).to.eql(pm.environment.get('test_member_number'));",
									"});",
									"",
									"pm.test(\"Member has audit fields populated\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.dateInserted).to.exist;",
									"    pm.expect(jsonData.data.userID).to.exist;",
									"    pm.expect(jsonData.data.userID).to.not.be.empty;",
									"});",
									"",
									"pm.test(\"DateDeleted is null for new member\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.dateDeleted).to.be.null;",
									"});",
									"",
									"// Save member ID for subsequent tests",
									"var jsonData = pm.response.json();",
									"pm.environment.set('created_member_id', jsonData.data.memberId);",
									"console.log('Created Member ID: ' + jsonData.data.memberId);"
