      <Textbox Name="IsMA">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Standard Notes</Value>
                <Style>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>Underline</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <Style />
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>This authorisation is only valid for the specified member, accommodation level and codes and is dependent on active membership, benefit sub-limits and available benefits at date of service.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style />
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>It is essential to contact the managed healthcare agent in the event of changes in the date of service, length of stay, level of care or scope of this authorisation request.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style />
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Please note that should the patient's stay be extended and we do not receive an appropriate clinical motivation Healthshare may decline funding of the changes.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style />
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>All accounts to be sent by registered post or courier or hand delivered to Healthshare. </Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
              <TextRun>
                <Value>Please send 2 original copies together with </Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>Red</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>Referral Request Form</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>Underline</TextDecoration>
                  <Color>Red</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value> and </Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>Red</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>Authorisation Number.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>Underline</TextDecoration>
                  <Color>Red</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0cm</LeftIndent>
            <RightIndent>0cm</RightIndent>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Every Service Provider who renders a service to a Swaziland patient, must obtain their own authorisation on commencement of service, by requesting authorisation from Healthshare by: 
     Fax to mail : +27 (0) 86 617 3037 
     Or E-MAIL: casemanagement.swazi@healthshare.co.za. 
Failure to obtain authorisation within 7 days could result to rejection of your claim</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0cm</LeftIndent>
            <RightIndent>0cm</RightIndent>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Claims older than 90 days will be regarded as stale.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0cm</LeftIndent>
            <RightIndent>0cm</RightIndent>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Ministry of Health Swaziland will pay 2009 NHRPL+ 233.90% for 2025, unless agreed for a different fee structure with Dr T de Coito from Healthshare. (drtdecoito@healthshare.co.za)</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0cm</LeftIndent>
            <RightIndent>0cm</RightIndent>
            <ListStyle>Numbered</ListStyle>
            <ListLevel>1</ListLevel>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Ministry of Health Swaziland will pay 2009 NHRPL+ </Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
