<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="MedManage">
      <DataSourceReference>MedManage</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3382a7d8-a157-4143-b35a-5a88750cca38</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CaseID">
            <Value>=Parameters!CaseID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        a.AuditID, a.UserName, a.ObjectName, CASE a.EventType WHEN 'I' THEN 'Insert' WHEN 'U' THEN 'Update' WHEN 'D' THEN 'Delete' END AS EventType, a.EventTime, a.ID1, a.ID2, a.ID3, ad.AuditDetailID, 
                         ad.AuditID AS Expr1, ad.FieldName, ad.OldValue, ad.NewValue
FROM            audit.CaseManagement_Audit AS a INNER JOIN
                         audit.CaseManagement_AuditDetail AS ad ON a.AuditID = ad.AuditID
WHERE        (a.ID1 = 'CaseID = ' + @CaseID) AND (a.ObjectName &lt;&gt; 'Session_User_Case') AND (ad.FieldName &lt;&gt; 'UserID') AND (a.ObjectName &lt;&gt; 'Case_Checklist')
ORDER BY a.ObjectName</CommandText>
      </Query>
      <Fields>
        <Field Name="AuditID">
          <DataField>AuditID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UserName">
          <DataField>UserName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ObjectName">
          <DataField>ObjectName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EventType">
          <DataField>EventType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EventTime">
          <DataField>EventTime</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ID1">
          <DataField>ID1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID2">
          <DataField>ID2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID3">
          <DataField>ID3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AuditDetailID">
          <DataField>AuditDetailID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Expr1">
          <DataField>Expr1</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FieldName">
          <DataField>FieldName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OldValue">
          <DataField>OldValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NewValue">
          <DataField>NewValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
