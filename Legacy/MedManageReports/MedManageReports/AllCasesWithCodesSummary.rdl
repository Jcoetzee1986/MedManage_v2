<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:cl="http://schemas.microsoft.com/sqlserver/reporting/2010/01/componentdefinition" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="MedManage">
      <DataSourceReference>MedManage</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>41bdeb3b-b41c-48ec-b997-cb356bb037aa</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="AllCasesData_AllTariffs">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MainClientID">
            <Value>=Parameters!MainClientID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--DECLARE @StartDate DateTime
--DECLARE @EndDate DateTime
--DECLARE @MainClientID int

--SELECT @StartDate = '2015-06-01'
--	, @EndDate = '2015-06-30'
--	, @MainClientID = 4

SELECT stat.CaseStatus
	,c.AuthNumber
	, c.AccountNr
	, ma.CasePrefix
	, m.MemberNumber
	, m.Name
	, m.Surname
	, m.Initials
	, m.DateOfBirth
	, g.GenderCode
	, ReferTo = rto.PracticeName
	, ReferFrom = rfrom.PracticeName
	, c.AdmissionDate
	, c.AdmissionTime
	, c.DischargeDate
	, c.DischargeTime
	, PrimaryICD = ISNULL(MAX(DiagnosisCode),'')
	, PrimaryCPT = ISNULL(MAX(CPT.Code),'')
	, PrimaryICDDesc = ISNULL(MAX(DiagnosisDesc),'')
	, PrimaryICDChapter = ISNULL(MAX([GroupDesc]),'')
	, PrimaryCPTDesc = ISNULL(MAX(CPT.MEDIUM_DESCR),'')
	, ReferToPracticeNumber = rto.PracticeNr
	, ReferFromPracticeNumber = rfrom.PracticeNr
	, c.UserID
	, c.DateCreated
	, c.CaseID
	, m.MedicalAidID
	--, ec.EpisodeID
	, FacilityType = ISNULL(ft.FacilityType,'')
	, cft.LOS
	, TotalLengthOfStay
	, cn.CaseNote
	, c.TotalAmount
	, c.FinalInvoiceAmount
	, c.FinalInvoiceAmountUpdated
	, map.MedAidProductName
	, m.MBOD_RMA
	,c.[HasBooking]
	,c.[ChangeToCaseDate]
	,TariffAmount = [dbo].[fn_sc_TotalTariffPerCase](c.CaseID)
FROM CaseManagement.Cases AS c INNER JOIN
	shared.Member AS m ON c.MemberID = m.MemberID INNER JOIN
	Shared.MedicalAid ma ON ma.MedicalAidID = m.MedicalAidID INNER JOIN 
	shared.ServiceProvider AS rto ON c.ReferToID = rto.ServiceProviderID LEFT JOIN
	shared.ServiceProvider AS rfrom ON c.ReferFromID = rfrom.ServiceProviderID LEFT JOIN
	CaseManagement.CaseStatus AS stat ON stat.CaseStatusID = c.StatusID LEFT JOIN 
	--CaseManagement.Episode_Case ec ON ec.CaseID = c.CaseID LEFT JOIN 
	CaseManagement.Case_ICD ON Case_ICD.CaseID = c.CaseID AND Case_ICD.PrimaryCode = 1 LEFT JOIN 
	shared.ICD ON ICD.ICDID = Case_ICD.ICDID LEFT JOIN
	CaseManagement.Case_CPT ON Case_CPT.CaseID = c.CaseID AND Case_CPT.PrimaryCode = 1 LEFT JOIN 
	shared.CPT ON CPT.CPTID = Case_CPT.CPTID LEFT JOIN 
	CaseManagement.Case_FacilityType cft ON cft.CaseID = c.CaseID
	LEFT JOIN shared.FacilityType ft ON ft.FacilityTypeID = cft.FacilityTypeID
	LEFT JOIN (SELECT CaseNoteID = MAX(CaseNoteID),CaseID FROM CaseManagement.CaseNote GROUP BY CaseID) cni ON cni.CaseID = c.CaseID
	LEFT JOIN CaseManagement.CaseNote cn ON cn.CaseNoteID = cni.CaseNoteID
		AND cn.CaseID = cni.CaseID
  LEFT JOIN [shared].[MedicalAidProduct] map ON map.MedAidProductID = m.MedAidProductID
  LEFT JOIN Shared.Gender g on m.GenderID = g.GenderID
WHERE  c.AdmissionDate BETWEEN @StartDate and @EndDate
    AND ma.MainClientID = @MainClientID
GROUP BY stat.CaseStatus
	,c.AuthNumber
	, c.AccountNr
	, ma.CasePrefix
	, m.MemberNumber
	, m.Name
	, m.Surname
	, m.Initials
	, m.DateOfBirth
	, g.GenderCode
	, rto.PracticeNr
	, rto.PracticeName
	, rfrom.PracticeNr
	, rfrom.PracticeName
	, c.AdmissionDate
	, c.AdmissionTime
	, c.DischargeDate
	, c.DischargeTime
	, c.CaseID
	, m.MedicalAidID
	, c.UserID
	--, ec.EpisodeID
	, c.DateCreated
	, ISNULL(ft.FacilityType,'')
	, TotalLengthOfStay
	, cft.LOS
	, cn.CaseNote
	, c.TotalAmount
	, c.FinalInvoiceAmount
	, c.FinalInvoiceAmountUpdated
	, map.MedAidProductName
	, m.MBOD_RMA
	,c.[HasBooking]
	,c.[ChangeToCaseDate]
ORDER BY c.DateCreated, m.Surname DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
