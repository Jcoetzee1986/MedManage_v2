          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MainClientName">
          <DataField>MainClientName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
