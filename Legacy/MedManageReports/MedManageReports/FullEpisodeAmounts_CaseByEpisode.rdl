  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ParentCase">
            <Value>=Parameters!ParentCase.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT * 
FROM vw_CaseDetail_WithAmounts
WHERE CaseID = @ParentCase
UNION
SELECT TOP(100)* 
FROM vw_CaseDetail_WithAmounts
WHERE ParentCase = @ParentCase</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
