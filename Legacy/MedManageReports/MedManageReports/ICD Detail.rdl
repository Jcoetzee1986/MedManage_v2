<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:cl="http://schemas.microsoft.com/sqlserver/reporting/2010/01/componentdefinition" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="MedManage">
      <DataSourceReference>MedManage</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>c67c5d34-218e-4937-a3b8-44a7d9f12743</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MainClientID">
            <Value>=Parameters!MainClientID.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
	 CaseID
	, ICDCode
	, CodeType = CASE WHEN ICDPrimary = 1 THEN '  Primary'
			WHEN ICDSecondary = 1 THEN ' Secondary'
			ELSE 'Co-Morbidity'
		END
	, ICDDesc
	, i.GroupCode
	, i.GroupDesc
FROM Overnight.AllCodesData a
LEFT JOIN [shared].[ICD] i ON i.DiagnosisCode = a.ICDCode
WHERE ICDCode IS NOT NULL
AND MainClientID = @MainClientID 
AND AdmissionDate BETWEEN @StartDate and @EndDate
Order by CaseID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CaseID">
          <DataField>CaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ICDCode">
          <DataField>ICDCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CodeType">
          <DataField>CodeType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ICDDesc">
          <DataField>ICDDesc</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GroupCode">
          <DataField>GroupCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GroupDesc">
          <DataField>GroupDesc</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MainClient">
      <SharedDataSet>
        <SharedDataSetReference>MainClient</SharedDataSetReference>
      </SharedDataSet>
      <Fields>
        <Field Name="MainClientID">
          <DataField>MainClientID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MainClientName">
          <DataField>MainClientName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
