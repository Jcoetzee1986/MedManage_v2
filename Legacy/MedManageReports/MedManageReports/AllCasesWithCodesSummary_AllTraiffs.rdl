<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:cl="http://schemas.microsoft.com/sqlserver/reporting/2010/01/componentdefinition" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="MedManage">
      <DataSourceReference>MedManage</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>41bdeb3b-b41c-48ec-b997-cb356bb037aa</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MainClientID">
            <Value>=Parameters!MainClientID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--DROP TABLE #Temp

--DECLARE @StartDate DateTime
--DECLARE @EndDate DateTime
--DECLARE @MainClientID int

--SELECT @StartDate = '2016-02-01'
--	, @EndDate = '2016-05-05'
--	, @MainClientID = 5;

WITH Case_ICD AS (SELECT CaseID, ICDID = MAX(ICDID) FROM CaseManagement.Case_ICD WHERE Case_ICD.PrimaryCode = 1 GROUP BY CaseID)
	,Case_CPT AS (SELECT CaseID, CPTID = MAX(CPTID) FROM CaseManagement.Case_CPT WHERE Case_CPT.PrimaryCode = 1 GROUP BY CaseID)
	,cni AS (SELECT CaseNoteID = MAX(CaseNoteID),CaseID FROM CaseManagement.CaseNote GROUP BY CaseID)
	,TariffCalc AS (SELECT CaseID, BaseTariffID, Value = SUM(Value), TotalPayable = SUM(TotalPayable) FROM [Overnight].[TariffCalc] GROUP BY CaseID, BaseTariffID)
SELECT ID = IDENTITY (INT,1,1)
	,stat.CaseStatus
	,c.AuthNumber
	, c.AccountNr
	, ma.CasePrefix
	, m.MemberNumber
	, m.Name
	, m.Surname
	, m.Initials
	, m.DateOfBirth
	, g.GenderCode
	, ReferTo = rto.PracticeName
	, ReferFrom = rfrom.PracticeName
	, c.AdmissionDate
	, c.AdmissionTime
	, c.DischargeDate
	, c.DischargeTime
	, PrimaryICD = ISNULL(DiagnosisCode,'')
	, PrimaryCPT = ISNULL(CPT.Code,'')
	, PrimaryICDDesc = ISNULL(DiagnosisDesc,'')
	, PrimaryICDChapter = ISNULL([GroupDesc],'')
	, PrimaryCPTDesc = ISNULL(CPT.MEDIUM_DESCR,'')
	, ReferToPracticeNumber = rto.PracticeNr
	, ReferFromPracticeNumber = rfrom.PracticeNr
	, c.UserID
	, c.DateCreated
	, c.CaseID
	, m.MedicalAidID
	--, ec.EpisodeID
	--, FacilityType = ISNULL(ft.FacilityType,'')
	--, cft.LOS
	, TotalLengthOfStay
	, cn.CaseNote
	, c.TotalAmount
	, c.FinalInvoiceAmount
	, c.FinalInvoiceAmountUpdated
	, map.MedAidProductName
	, m.MBOD_RMA
	,c.[HasBooking]
	,c.[ChangeToCaseDate]
	, TariffAmount = ISNULL(tc.[TotalPayable],0.00)
	, TariffLineValue = ISNULL(tc.Value,0.00)
	, tc.Value
	, TariffDescription = bt.TariffDescription
	, bt.BaseTariffID
	, Seq = 0
INTO #Temp
FROM CaseManagement.Cases AS c INNER JOIN
	shared.Member AS m ON c.MemberID = m.MemberID INNER JOIN
	Shared.MedicalAid ma ON ma.MedicalAidID = m.MedicalAidID INNER JOIN 
	shared.ServiceProvider AS rto ON c.ReferToID = rto.ServiceProviderID LEFT JOIN
	shared.ServiceProvider AS rfrom ON c.ReferFromID = rfrom.ServiceProviderID LEFT JOIN
	CaseManagement.CaseStatus AS stat ON stat.CaseStatusID = c.StatusID LEFT JOIN 
	Case_ICD ON Case_ICD.CaseID = c.CaseID  LEFT JOIN 
	shared.ICD ON ICD.ICDID = Case_ICD.ICDID LEFT JOIN
	Case_CPT ON Case_CPT.CaseID = c.CaseID LEFT JOIN 
	shared.CPT ON CPT.CPTID = Case_CPT.CPTID 
	LEFT JOIN cni ON cni.CaseID = c.CaseID
	LEFT JOIN CaseManagement.CaseNote cn ON cn.CaseNoteID = cni.CaseNoteID
		AND cn.CaseID = cni.CaseID
	LEFT JOIN [shared].[MedicalAidProduct] map ON map.MedAidProductID = m.MedAidProductID
	LEFT JOIN Shared.Gender g on m.GenderID = g.GenderID
	LEFT JOIN [TariffCalc] tc ON tc.CaseID = c.CaseID
	LEFT JOIN [Tariff].[BaseTariff] bt on tc.BaseTariffID = bt.BaseTariffID
		AND bt.TariffStructureID = rto.TariffStructureID
WHERE  c.AdmissionDate BETWEEN @StartDate and @EndDate
    AND ma.MainClientID = @MainClientID
ORDER BY c.AuthNumber, c.DateCreated, m.Surname DESC

DECLARE @RowCount INT = 0;
DECLARE @cnt INT = 0;
WHILE @cnt &lt; (SELECT COUNT(1) FROM #Temp)
BEGIN
	IF (@cnt = 0)
	BEGIN
		SET @RowCount = 0
	END
	ELSE IF (SELECT CaseID FROM #Temp WHERE ID = @cnt) = (SELECT CaseID FROM #Temp WHERE ID = @cnt - 1)
	BEGIN
		SET @RowCount = @RowCount + 1
	END
	ELSE BEGIN
		SET @RowCount = 0
	END

	UPDATE #TEMP
	SET Seq = @RowCount
	WHERE ID = @cnt
   --PRINT 'Inside simulated FOR LOOP on TechOnTheNet.com';
   SET @cnt = @cnt + 1;
END;

SELECT * FROM #Temp</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
