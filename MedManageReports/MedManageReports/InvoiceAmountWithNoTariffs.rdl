    <DataSet Name="Summary">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MainClientID">
            <Value>=Parameters!MainClientID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>

IF OBJECT_ID('tempdb..#AuditTemp') IS NOT NULL
    DROP TABLE #AuditTemp

SELECT AuditID = MAX(a.AuditID)
	, CaseID = REPLACE(a.ID1,'CaseID = ','')
INTO #AuditTemp
FROM [audit].CaseManagement_Audit a
INNER JOIN [audit].CaseManagement_AuditDetail ad
	ON a.AuditID = ad.AuditID
WHERE a.ObjectName = 'Cases'
	AND ad.FieldName = 'FinalInvoiceAmount'
	AND a.EventType = 'U'
	AND [EventTime] BETWEEN @StartDate AND @EndDate
GROUP BY a.ID1

SELECT InvoiceUserName = a.UserName
	, CasesAudited = COUNT(cd.CaseID)
	, NoTariffs = COUNT(ct.CaseID)
	, FinalInvoiceAmount = SUM(cd.FinalInvoiceAmount)
	, TariffValue = SUM(ct.Value)

FROM vw_CaseDetail cd
INNER JOIN (SELECT CaseID, [UserName]
			FROM #AuditTemp ta
			INNER JOIN [audit].CaseManagement_Audit a
				ON ta.AuditID = a.AuditID) a
	ON a.CaseID = cd.CaseID
LEFT JOIN (SELECT CaseID
			, Value = SUM(Value)
		FROM [Tariff].[Case_Tariff]
		GROUP BY CaseID) ct
	ON cd.CaseID = ct.CaseID
WHERE Convert(DATETIME,[FinalInvoiceAmountUpdated]) BETWEEN @StartDate AND @EndDate
	AND MainClientID = @MainClientID
GROUP BY a.UserName

</CommandText>
      </Query>
      <Fields>
        <Field Name="InvoiceUserName">
          <DataField>InvoiceUserName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CasesAudited">
          <DataField>CasesAudited</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NoTariffs">
          <DataField>NoTariffs</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FinalInvoiceAmount">
          <DataField>FinalInvoiceAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TariffValue">
          <DataField>TariffValue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
