                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>This report show all cases where the final invlice amount was updated  by the person selected in the specified period as well as all the tariffs added to the specified period for those cases</Value>
                    <Style>
                      <FontStyle>Italic</FontStyle>
                      <FontFamily>Tahoma</FontFamily>
