  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="MedManage">
      <DataSourceReference>MedManage</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>0b5d5b08-e372-4053-99ed-7decd9b5d230</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>MedManage</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT a.AuditID
, a.UserName
, CASE a.EventType WHEN 'I' THEN 'Insert' WHEN 'U' THEN 'Update' WHEN 'D' THEN 'Delete' END AS EventType
, EventTime = Convert(Varchar(10),a.EventTime)
, a.ID1
FROM audit.CaseManagement_Audit AS a 
WHERE (Convert(Date,a.EventTime) BETWEEN @StartDate AND @EndDate) 
	AND (a.ObjectName = 'Cases') 
	AND EventType = 'I'
ORDER BY a.ObjectName</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AuditID">
          <DataField>AuditID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UserName">
          <DataField>UserName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EventType">
          <DataField>EventType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EventTime">
          <DataField>EventTime</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID1">
          <DataField>ID1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
